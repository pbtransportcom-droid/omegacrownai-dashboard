{
  "name": "sovereign-runtime",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "qa:artifact-matrix": "node scripts/artifact-matrix-smoke.mjs",
    "qa:artifact-live-fast": "node scripts/artifact-live-fast-smoke.mjs",
    "qa:artifact-live-fast:live": "LIVE_CHECK=1 node scripts/artifact-live-fast-smoke.mjs",
    "qa:artifact-release": "npm run build && npm run qa:artifact-matrix && npm run qa:artifact-live-fast:live && npm run qa:artifact-download:live && npm run qa:website-prompt-acceptance && npm run qa:generated-backend-live",
    "qa:artifact-download": "node scripts/artifact-download-route-smoke.mjs",
    "qa:artifact-download:live": "LIVE_CHECK=1 node scripts/artifact-download-route-smoke.mjs",
    "qa:website-prompt-acceptance": "node scripts/website-prompt-acceptance-smoke.mjs",
    "qa:generated-backend-live": "node scripts/generated-backend-live-smoke.mjs",
    "live-proof": "node scripts/generated-live-proof.mjs"
  },
  "dependencies": {
    "bullmq": "^5.34.5",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "ioredis": "^5.4.2",
    "pg": "^8.13.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.7",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
