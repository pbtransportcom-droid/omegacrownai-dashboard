{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "public/runtime-deployments",
    "public/runtime-deployments/**/*",
    "services/sovereign-runtime/data",
    "services/sovereign-runtime/data/**/*",
    "services/sovereign-runtime/generated-apps",
    "services/sovereign-runtime/generated-apps/**/*",
    "services/sovereign-runtime/data/artifacts",
    "services/sovereign-runtime/data/artifacts/**/*"
  ]
}
