generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(cuid())
  name         String?
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())

  projects Project[]
}

model Project {
  id        String   @id @default(cuid())
  name      String
  owner     User     @relation(fields: [ownerId], references: [id])
  ownerId   String
  createdAt DateTime @default(now())

  chatThreads    ChatThread[]
  executions     AgentExecution[]
  builds         ProjectBuild[]
  auditLogs      AuditLog[]
  safetySettings ProjectSafetySettings?
  cloudJobs      CloudJob[]
}

model ChatThread {
  id        String   @id @default(cuid())
  project   Project  @relation(fields: [projectId], references: [id])
  projectId String
  title     String   @default("Project Chat")
  createdAt DateTime @default(now())

  messages ChatMessage[]
}

model ChatMessage {
  id        String     @id @default(cuid())
  thread    ChatThread @relation(fields: [threadId], references: [id])
  threadId  String
  role      String
  content   String
  createdAt DateTime   @default(now())
}

model AgentExecution {
  id        String   @id @default(cuid())
  project   Project  @relation(fields: [projectId], references: [id])
  projectId String
  prompt    String
  intents   Json
  agents    Json
  execution Json
  reply     String
  createdAt DateTime @default(now())
}

model ProjectBuild {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id])

  label  String
  status String @default("draft")
  source String @default("brain_auto")
  domain String @default("website")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  artifacts ProjectBuildArtifact[]

  @@index([projectId])
  @@index([domain])
  @@index([status])
}

model ProjectBuildArtifact {
  id        String @id @default(cuid())
  projectId String
  buildId   String

  build ProjectBuild @relation(fields: [buildId], references: [id])

  kind    String
  payload Json

  createdAt DateTime @default(now())

  @@index([projectId])
  @@index([buildId])
  @@index([kind])
}

model TradingWatchlist {
  id         String   @id @default(cuid())
  ownerEmail String   @unique
  name       String   @default("Default Watchlist")
  symbols    String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model TradingSignalAlert {
  id            String   @id @default(cuid())
  ownerEmail    String   @unique
  signal        String   @default("BUY WATCH")
  minConfidence Int      @default(75)
  isEnabled     Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model PublishedSite {
  id          String   @id @default(cuid())
  slug        String   @unique
  executionId String   @unique
  projectId   String
  ownerEmail  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model GuestAiUsage {
  id        String   @id @default(cuid())
  usageKey  String   @unique
  count     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([usageKey])
}

model SugentEvent {
  id String @id @default(cuid())

  projectId   String?
  buildId     String?
  artifactId  String?
  executionId String?

  type    String
  domain  String?
  actor   String?
  message String
  payload Json?

  createdAt DateTime @default(now())

  @@index([projectId])
  @@index([buildId])
  @@index([artifactId])
  @@index([executionId])
  @@index([type])
  @@index([domain])
  @@index([createdAt])
}

model AuditLog {
  id String @id @default(cuid())

  projectId String
  project   Project @relation(fields: [projectId], references: [id])

  actorType String
  actorId   String?

  action   String
  metadata Json

  createdAt DateTime @default(now())

  @@index([projectId])
  @@index([actorType])
  @@index([action])
  @@index([createdAt])
}

model ProjectSafetySettings {
  id String @id @default(cuid())

  projectId String  @unique
  project   Project @relation(fields: [projectId], references: [id])

  tradingMaxLeverage         Int     @default(5)
  automationAllowExternal    Boolean @default(false)
  websiteAllowCustomScripts  Boolean @default(false)
  requireReviewBeforePublish Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
}

model CloudJob {
  id String @id @default(cuid())

  projectId String
  project   Project @relation(fields: [projectId], references: [id])

  buildId String?
  type    String
  status  String  @default("queued")
  payload Json
  result  Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([buildId])
  @@index([type])
  @@index([status])
  @@index([createdAt])
}

model MarketplaceAgent {
  id           String @id @default(cuid())
  name         String
  description  String
  version      String @default("1.0.0")
  inputSchema  Json
  outputSchema Json
  endpoint     String
  status       String @default("active")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
}

model MarketplaceTool {
  id           String @id @default(cuid())
  name         String
  description  String
  configSchema Json
  endpoint     String
  status       String @default("active")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
}

model MarketplaceTemplate {
  id          String @id @default(cuid())
  name        String
  description String
  domain      String
  draftKind   String
  draft       Json
  status      String @default("active")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([domain])
  @@index([draftKind])
  @@index([status])
  @@index([createdAt])
}

model TimelineEvent {
  id String @id @default(cuid())

  sessionId String
  projectId String?

  type    String
  payload Json

  createdAt DateTime @default(now())

  @@index([sessionId])
  @@index([projectId])
  @@index([type])
  @@index([createdAt])
}

model TimelineSnapshot {
  id String @id @default(cuid())

  sessionId String
  projectId String?

  index Int
  state Json

  createdAt DateTime @default(now())

  @@index([sessionId])
  @@index([projectId])
  @@index([index])
  @@index([createdAt])
}

model MemoryRecord {
  id String @id @default(cuid())

  projectId String?
  sessionId String?

  type      String
  content   String
  embedding Json
  score     Float    @default(0)
  tags      String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([sessionId])
  @@index([type])
  @@index([score])
  @@index([createdAt])
}

model UserRole {
  id String @id @default(cuid())

  userId    String
  role      String
  projectId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, projectId])
  @@index([userId])
  @@index([projectId])
  @@index([role])
}

model DistributionPackage {
  id String @id @default(cuid())

  projectId String?
  version   String  @default("1.0.0")
  type      String
  manifest  Json
  payload   Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([type])
  @@index([version])
  @@index([createdAt])
}

model ExecutionRecord {
  id String @id @default(cuid())

  projectId        String?
  sessionId        String?
  runtimeSessionId String?

  language String
  status   String @default("queued")

  code       String
  codeHash   String
  inputHash  String
  outputHash String?

  input   Json
  output  Json?
  logs    Json
  error   String?
  metrics Json
  policy  Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([sessionId])
  @@index([runtimeSessionId])
  @@index([language])
  @@index([status])
  @@index([codeHash])
  @@index([createdAt])
}

model ProjectExecutionPolicy {
  id String @id @default(cuid())

  projectId String @unique

  enabled Boolean @default(true)
  policy  Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([enabled])
  @@index([createdAt])
}

model BrowserTask {
  id String @id @default(cuid())

  projectId        String?
  sessionId        String?
  runtimeSessionId String?

  url    String
  status String @default("queued")

  title   String?
  text    String?
  html    String?
  result  Json?
  logs    Json
  error   String?
  metrics Json
  policy  Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([sessionId])
  @@index([runtimeSessionId])
  @@index([status])
  @@index([url])
  @@index([createdAt])
}

model BrowserArtifact {
  id String @id @default(cuid())

  taskId    String
  projectId String?

  kind      String
  name      String?
  path      String
  url       String?
  mimeType  String?
  sizeBytes Int?

  metadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([taskId])
  @@index([projectId])
  @@index([kind])
  @@index([createdAt])
}

model CloudSchedule {
  id String @id @default(cuid())

  projectId String
  name      String
  provider  String @default("local")
  type      String @default("generic")
  payload   Json

  enabled         Boolean   @default(true)
  intervalMinutes Int       @default(60)
  nextRunAt       DateTime
  lastRunAt       DateTime?
  lastJobId       String?
  runCount        Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([enabled])
  @@index([nextRunAt])
  @@index([provider])
  @@index([type])
}

model Company {
  id String @id @default(cuid())

  projectId String
  name      String
  mission   String?
  vision    String?

  idealCustomerProfile Json?
  primaryOffer         Json?
  channels             Json?

  status String @default("active")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  kpis        CompanyKPI[]
  memory      CompanyMemory[]
  tasks       CompanyTask[]
  workers     Worker[]
  departments CompanyDepartment[]

  @@index([projectId])
  @@index([status])
  @@index([createdAt])
}

model CompanyKPI {
  id String @id @default(cuid())

  companyId String
  metric    String
  value     Float
  period    String  @default("week")
  note      String?

  timestamp DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([metric])
  @@index([period])
  @@index([timestamp])
}

model CompanyMemory {
  id String @id @default(cuid())

  companyId String
  kind      String @default("fact")
  content   String
  tags      Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([kind])
  @@index([createdAt])
}

model Worker {
  id String @id @default(cuid())

  companyId String
  role      String
  name      String
  status    String @default("idle")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  tasks   CompanyTask[]

  @@index([companyId])
  @@index([role])
  @@index([status])
}

model CompanyTask {
  id String @id @default(cuid())

  companyId String
  workerId  String?

  type   String
  input  Json
  output Json?

  status       String  @default("pending")
  errorMessage String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  worker  Worker? @relation(fields: [workerId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([workerId])
  @@index([type])
  @@index([status])
  @@index([createdAt])
}

model SecurityAuditEvent {
  id String @id @default(cuid())

  level     String  @default("info")
  action    String
  route     String?
  method    String?
  ip        String?
  actorId   String?
  actorType String?
  userAgent String?

  allowed  Boolean @default(false)
  reason   String?
  metadata Json?

  createdAt DateTime @default(now())

  @@index([level])
  @@index([action])
  @@index([route])
  @@index([ip])
  @@index([actorId])
  @@index([allowed])
  @@index([createdAt])
}

model CompanyDepartment {
  id String @id @default(cuid())

  companyId String
  name      String
  slug      String
  purpose   String?
  status    String  @default("active")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  kpis   DepartmentKPI[]
  memory DepartmentMemory[]

  @@unique([companyId, slug])
  @@index([companyId])
  @@index([slug])
  @@index([status])
}

model DepartmentKPI {
  id String @id @default(cuid())

  departmentId String
  metric       String
  value        Float
  period       String  @default("week")
  note         String?

  timestamp DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  department CompanyDepartment @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@index([departmentId])
  @@index([metric])
  @@index([period])
  @@index([timestamp])
}

model DepartmentMemory {
  id String @id @default(cuid())

  departmentId String
  kind         String @default("fact")
  content      String
  tags         Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  department CompanyDepartment @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@index([departmentId])
  @@index([kind])
  @@index([createdAt])
}

model MarketingAudience {
  id String @id @default(cuid())

  companyId    String
  departmentId String?

  name        String
  segment     String?
  description String?
  painPoints  Json?
  goals       Json?
  channels    Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([departmentId])
  @@index([name])
}

model MarketingCampaign {
  id String @id @default(cuid())

  companyId    String
  departmentId String?

  name      String
  objective String
  offer     String?
  audience  Json?
  channels  Json?
  status    String  @default("draft")

  brief   Json?
  metrics Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assets MarketingAsset[]

  @@index([companyId])
  @@index([departmentId])
  @@index([status])
  @@index([createdAt])
}

model MarketingAsset {
  id String @id @default(cuid())

  campaignId String
  type       String
  title      String
  content    String
  channel    String?
  status     String  @default("draft")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  campaign MarketingCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@index([type])
  @@index([channel])
  @@index([status])
}

model SalesPipeline {
  id String @id @default(cuid())

  companyId    String
  departmentId String?

  name        String
  description String?
  stages      Json?
  status      String  @default("active")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  leads SalesLead[]
  deals SalesDeal[]

  @@index([companyId])
  @@index([departmentId])
  @@index([status])
}

model SalesLead {
  id String @id @default(cuid())

  companyId    String
  departmentId String?
  pipelineId   String?

  name    String
  company String?
  email   String?
  phone   String?
  source  String?
  status  String  @default("new")
  score   Float   @default(0)

  notes    String?
  metadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  pipeline SalesPipeline? @relation(fields: [pipelineId], references: [id], onDelete: SetNull)
  deals    SalesDeal[]

  @@index([companyId])
  @@index([departmentId])
  @@index([pipelineId])
  @@index([status])
  @@index([score])
}

model SalesDeal {
  id String @id @default(cuid())

  companyId    String
  departmentId String?
  pipelineId   String?
  leadId       String?

  name        String
  stage       String @default("qualified")
  value       Float  @default(0)
  currency    String @default("USD")
  probability Float  @default(0.25)
  status      String @default("open")

  nextStep String?
  notes    String?
  metadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  pipeline SalesPipeline? @relation(fields: [pipelineId], references: [id], onDelete: SetNull)
  lead     SalesLead?     @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([departmentId])
  @@index([pipelineId])
  @@index([leadId])
  @@index([stage])
  @@index([status])
}

model FinanceAccount {
  id String @id @default(cuid())

  companyId    String
  departmentId String?

  name     String
  type     String @default("operating")
  currency String @default("USD")
  balance  Float  @default(0)
  status   String @default("active")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transactions FinanceTransaction[]

  @@index([companyId])
  @@index([departmentId])
  @@index([type])
  @@index([status])
}

model FinanceTransaction {
  id String @id @default(cuid())

  companyId    String
  departmentId String?
  accountId    String?

  type        String
  category    String
  amount      Float
  currency    String  @default("USD")
  description String?
  metadata    Json?

  occurredAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  account FinanceAccount? @relation(fields: [accountId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([departmentId])
  @@index([accountId])
  @@index([type])
  @@index([category])
  @@index([occurredAt])
}

model FinanceForecast {
  id String @id @default(cuid())

  companyId    String
  departmentId String?

  name         String
  period       String @default("month")
  revenue      Float  @default(0)
  expenses     Float  @default(0)
  cashBalance  Float  @default(0)
  runwayMonths Float  @default(0)

  assumptions Json?
  result      Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([departmentId])
  @@index([period])
  @@index([createdAt])
}

model OperationsProcess {
  id String @id @default(cuid())

  companyId    String
  departmentId String?

  name        String
  description String?
  status      String  @default("active")
  priority    String  @default("medium")

  steps     Json?
  ownerRole String?
  metrics   Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  checklists OperationsChecklist[]
  runs       OperationsRun[]

  @@index([companyId])
  @@index([departmentId])
  @@index([status])
  @@index([priority])
}

model OperationsChecklist {
  id String @id @default(cuid())

  companyId    String
  departmentId String?
  processId    String?

  title  String
  items  Json?
  status String @default("draft")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  process OperationsProcess? @relation(fields: [processId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([departmentId])
  @@index([processId])
  @@index([status])
}

model OperationsRun {
  id String @id @default(cuid())

  companyId    String
  departmentId String?
  processId    String?

  status      String    @default("completed")
  startedAt   DateTime  @default(now())
  completedAt DateTime?
  result      Json?
  notes       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  process OperationsProcess? @relation(fields: [processId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([departmentId])
  @@index([processId])
  @@index([status])
  @@index([startedAt])
}

model SupportTicket {
  id String @id @default(cuid())

  companyId    String
  departmentId String?

  customerName  String?
  customerEmail String?
  subject       String
  message       String
  category      String  @default("general")
  priority      String  @default("normal")
  status        String  @default("open")

  sentiment String?
  metadata  Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  responses SupportResponse[]

  @@index([companyId])
  @@index([departmentId])
  @@index([category])
  @@index([priority])
  @@index([status])
  @@index([createdAt])
}

model SupportKnowledgeBase {
  id String @id @default(cuid())

  companyId    String
  departmentId String?

  title    String
  slug     String
  content  String
  category String @default("general")
  status   String @default("draft")
  tags     Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, slug])
  @@index([companyId])
  @@index([departmentId])
  @@index([category])
  @@index([status])
}

model SupportResponse {
  id String @id @default(cuid())

  companyId    String
  departmentId String?
  ticketId     String?

  subject  String?
  content  String
  tone     String  @default("professional")
  status   String  @default("draft")
  metadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ticket SupportTicket? @relation(fields: [ticketId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([departmentId])
  @@index([ticketId])
  @@index([status])
}

model ExecutiveSchedule {
  id String @id @default(cuid())

  projectId String
  companyId String?

  name      String
  frequency String @default("daily")
  hour      Int    @default(9)
  timezone  String @default("America/Chicago")
  status    String @default("active")

  lastRunAt DateTime?
  nextRunAt DateTime?
  metadata  Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  runs ExecutiveRunLog[]

  @@index([projectId])
  @@index([companyId])
  @@index([status])
  @@index([nextRunAt])
}

model ExecutiveRunLog {
  id String @id @default(cuid())

  projectId  String
  companyId  String?
  scheduleId String?

  type    String  @default("daily_report")
  status  String  @default("success")
  summary Json?
  report  Json?
  error   String?

  startedAt   DateTime  @default(now())
  completedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  schedule ExecutiveSchedule? @relation(fields: [scheduleId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([companyId])
  @@index([scheduleId])
  @@index([type])
  @@index([status])
  @@index([createdAt])
}

model VideoProject {
  id String @id @default(cuid())

  companyId       String
  campaignId      String?
  title           String
  description     String?
  status          String  @default("planned")
  aspectRatio     String  @default("16:9")
  durationSeconds Int?

  brandProfileId String?
  brandOverlay   Json?

  scriptId   String?
  timelineId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  script              VideoScript?
  timeline            VideoTimeline?
  scenes              VideoScene[]
  assets              VideoAsset[]
  renderJobs          RenderJob[]
  assetGenerationJobs AssetGenerationJob[]

  @@index([companyId])
  @@index([campaignId])
  @@index([status])
  @@index([createdAt])
}

model VideoScript {
  id String @id @default(cuid())

  projectId String  @unique
  fullText  String
  language  String  @default("en")
  tone      String?
  metadata  Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project VideoProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([language])
}

model VideoScene {
  id String @id @default(cuid())

  projectId     String
  index         Int
  title         String?
  scriptSegment String
  voiceoverText String

  startTimeSeconds Int?
  endTimeSeconds   Int?
  transitionIn     String?
  transitionOut    String?
  cameraStyle      String?

  metadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project             VideoProject         @relation(fields: [projectId], references: [id], onDelete: Cascade)
