generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(cuid())
  name         String?
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())

  projects     Project[]
}

model Project {
  id          String           @id @default(cuid())
  name        String
  owner       User             @relation(fields: [ownerId], references: [id])
  ownerId     String
  createdAt   DateTime         @default(now())

  chatThreads ChatThread[]
  executions  AgentExecution[]
  builds      ProjectBuild[]
  auditLogs   AuditLog[]
  safetySettings ProjectSafetySettings?
  cloudJobs   CloudJob[]
}

model ChatThread {
  id         String        @id @default(cuid())
  project    Project       @relation(fields: [projectId], references: [id])
  projectId  String
  title      String        @default("Project Chat")
  createdAt  DateTime      @default(now())

  messages   ChatMessage[]
}

model ChatMessage {
  id         String      @id @default(cuid())
  thread     ChatThread  @relation(fields: [threadId], references: [id])
  threadId   String
  role       String
  content    String
  createdAt  DateTime    @default(now())
}

model AgentExecution {
  id        String   @id @default(cuid())
  project   Project  @relation(fields: [projectId], references: [id])
  projectId String
  prompt    String
  intents   Json
  agents    Json
  execution Json
  reply     String
  createdAt DateTime @default(now())
}

model ProjectBuild {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id])

  label     String
  status    String   @default("draft")
  source    String   @default("brain_auto")
  domain    String   @default("website")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  artifacts ProjectBuildArtifact[]

  @@index([projectId])
  @@index([domain])
  @@index([status])
}

model ProjectBuildArtifact {
  id        String   @id @default(cuid())
  projectId String
  buildId   String

  build     ProjectBuild @relation(fields: [buildId], references: [id])

  kind      String
  payload   Json

  createdAt DateTime @default(now())

  @@index([projectId])
  @@index([buildId])
  @@index([kind])
}


model TradingWatchlist {
  id         String   @id @default(cuid())
  ownerEmail String  @unique
  name       String  @default("Default Watchlist")
  symbols    String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model TradingSignalAlert {
  id            String   @id @default(cuid())
  ownerEmail    String   @unique
  signal        String   @default("BUY WATCH")
  minConfidence Int      @default(75)
  isEnabled     Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model PublishedSite {
  id          String   @id @default(cuid())
  slug        String   @unique
  executionId String   @unique
  projectId   String
  ownerEmail  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model GuestAiUsage {
  id        String   @id @default(cuid())
  usageKey String   @unique
  count     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([usageKey])
}



model SugentEvent {
  id        String   @id @default(cuid())

  projectId String?
  buildId   String?
  artifactId String?
  executionId String?

  type      String
  domain    String?
  actor     String?
  message   String
  payload   Json?

  createdAt DateTime @default(now())

  @@index([projectId])
  @@index([buildId])
  @@index([artifactId])
  @@index([executionId])
  @@index([type])
  @@index([domain])
  @@index([createdAt])
}


model AuditLog {
  id        String   @id @default(cuid())

  projectId String
  project   Project  @relation(fields: [projectId], references: [id])

  actorType String
  actorId   String?

  action    String
  metadata  Json

  createdAt DateTime @default(now())

  @@index([projectId])
  @@index([actorType])
  @@index([action])
  @@index([createdAt])
}


model ProjectSafetySettings {
  id        String   @id @default(cuid())

  projectId String   @unique
  project   Project  @relation(fields: [projectId], references: [id])

  tradingMaxLeverage Int     @default(5)
  automationAllowExternal Boolean @default(false)
  websiteAllowCustomScripts Boolean @default(false)
  requireReviewBeforePublish Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
}


model CloudJob {
  id        String   @id @default(cuid())

  projectId String
  project   Project  @relation(fields: [projectId], references: [id])

  buildId   String?
  type      String
  status    String   @default("queued")
  payload   Json
  result    Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([buildId])
  @@index([type])
  @@index([status])
  @@index([createdAt])
}


model MarketplaceAgent {
  id          String   @id @default(cuid())
  name        String
  description String
  version     String   @default("1.0.0")
  inputSchema Json
  outputSchema Json
  endpoint    String
  status      String   @default("active")

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
}

model MarketplaceTool {
  id          String   @id @default(cuid())
  name        String
  description String
  configSchema Json
  endpoint    String
  status      String   @default("active")

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
}

model MarketplaceTemplate {
  id          String   @id @default(cuid())
  name        String
  description String
  domain      String
  draftKind   String
  draft       Json
  status      String   @default("active")

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([domain])
  @@index([draftKind])
  @@index([status])
  @@index([createdAt])
}


model TimelineEvent {
  id        String   @id @default(cuid())

  sessionId String
  projectId String?

  type      String
  payload   Json

  createdAt DateTime @default(now())

  @@index([sessionId])
  @@index([projectId])
  @@index([type])
  @@index([createdAt])
}

model TimelineSnapshot {
  id        String   @id @default(cuid())

  sessionId String
  projectId String?

  index     Int
  state     Json

  createdAt DateTime @default(now())

  @@index([sessionId])
  @@index([projectId])
  @@index([index])
  @@index([createdAt])
}


model MemoryRecord {
  id        String   @id @default(cuid())

  projectId String?
  sessionId String?

  type      String
  content   String
  embedding Json
  score     Float    @default(0)
  tags      String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([sessionId])
  @@index([type])
  @@index([score])
  @@index([createdAt])
}


model UserRole {
  id        String   @id @default(cuid())

  userId    String
  role      String
  projectId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, projectId])
  @@index([userId])
  @@index([projectId])
  @@index([role])
}


model DistributionPackage {
  id        String   @id @default(cuid())

  projectId String?
  version   String   @default("1.0.0")
  type      String
  manifest  Json
  payload   Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([type])
  @@index([version])
  @@index([createdAt])
}


model ExecutionRecord {
  id        String   @id @default(cuid())

  projectId String?
  sessionId String?
  runtimeSessionId String?

  language  String
  status    String   @default("queued")

  code      String
  codeHash  String
  inputHash String
  outputHash String?

  input     Json
  output    Json?
  logs      Json
  error     String?
  metrics   Json
  policy    Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([sessionId])
  @@index([runtimeSessionId])
  @@index([language])
  @@index([status])
  @@index([codeHash])
  @@index([createdAt])
}


model ProjectExecutionPolicy {
  id        String   @id @default(cuid())

  projectId String   @unique

  enabled   Boolean  @default(true)
  policy    Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([enabled])
  @@index([createdAt])
}


model BrowserTask {
  id        String   @id @default(cuid())

  projectId String?
  sessionId String?
  runtimeSessionId String?

  url       String
  status    String   @default("queued")

  title     String?
  text      String?
  html      String?
  result    Json?
  logs      Json
  error     String?
  metrics   Json
  policy    Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([sessionId])
  @@index([runtimeSessionId])
  @@index([status])
  @@index([url])
  @@index([createdAt])
}


model BrowserArtifact {
  id        String   @id @default(cuid())

  taskId    String
  projectId String?

  kind      String
  name      String?
  path      String
  url       String?
  mimeType  String?
  sizeBytes Int?

  metadata  Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([taskId])
  @@index([projectId])
  @@index([kind])
  @@index([createdAt])
}


model CloudSchedule {
  id        String   @id @default(cuid())

  projectId String
  name      String
  provider  String   @default("local")
  type      String   @default("generic")
  payload   Json

  enabled   Boolean  @default(true)
  intervalMinutes Int @default(60)
  nextRunAt DateTime
  lastRunAt DateTime?
  lastJobId String?
  runCount  Int      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([enabled])
  @@index([nextRunAt])
  @@index([provider])
  @@index([type])
}


model Company {
  id        String   @id @default(cuid())

  projectId String
  name      String
  mission   String?
  vision    String?

  idealCustomerProfile Json?
  primaryOffer         Json?
  channels             Json?

  status    String   @default("active")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  kpis    CompanyKPI[]
  memory  CompanyMemory[]
  tasks   CompanyTask[]
  workers Worker[]

  @@index([projectId])
  @@index([status])
  @@index([createdAt])
}

model CompanyKPI {
  id        String   @id @default(cuid())

  companyId String
  metric    String
  value     Float
  period    String   @default("week")
  note      String?

  timestamp DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([metric])
  @@index([period])
  @@index([timestamp])
}

model CompanyMemory {
  id        String   @id @default(cuid())

  companyId String
  kind      String   @default("fact")
  content   String
  tags      Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([kind])
  @@index([createdAt])
}

model Worker {
  id        String   @id @default(cuid())

  companyId String
  role      String
  name      String
  status    String   @default("idle")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  tasks   CompanyTask[]

  @@index([companyId])
  @@index([role])
  @@index([status])
}

model CompanyTask {
  id        String   @id @default(cuid())

  companyId String
  workerId  String?

  type   String
  input  Json
  output Json?

  status       String  @default("pending")
  errorMessage String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  worker  Worker? @relation(fields: [workerId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([workerId])
  @@index([type])
  @@index([status])
  @@index([createdAt])
}


model SecurityAuditEvent {
  id        String   @id @default(cuid())

  level     String   @default("info")
  action    String
  route     String?
  method    String?
  ip        String?
  actorId   String?
  actorType String?
  userAgent String?

  allowed   Boolean  @default(false)
  reason    String?
  metadata  Json?

  createdAt DateTime @default(now())

  @@index([level])
  @@index([action])
  @@index([route])
  @@index([ip])
  @@index([actorId])
  @@index([allowed])
  @@index([createdAt])
}
