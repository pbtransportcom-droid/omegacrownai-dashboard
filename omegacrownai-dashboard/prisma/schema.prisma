generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(cuid())
  name         String?
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())

  projects     Project[]
}

model Project {
  id          String           @id @default(cuid())
  name        String
  owner       User             @relation(fields: [ownerId], references: [id])
  ownerId     String
  createdAt   DateTime         @default(now())

  chatThreads ChatThread[]
  executions  AgentExecution[]
  builds      ProjectBuild[]
  auditLogs   AuditLog[]
  safetySettings ProjectSafetySettings?
  cloudJobs   CloudJob[]
}

model ChatThread {
  id         String        @id @default(cuid())
  project    Project       @relation(fields: [projectId], references: [id])
  projectId  String
  title      String        @default("Project Chat")
  createdAt  DateTime      @default(now())

  messages   ChatMessage[]
}

model ChatMessage {
  id         String      @id @default(cuid())
  thread     ChatThread  @relation(fields: [threadId], references: [id])
  threadId   String
  role       String
  content    String
  createdAt  DateTime    @default(now())
}

model AgentExecution {
  id        String   @id @default(cuid())
  project   Project  @relation(fields: [projectId], references: [id])
  projectId String
  prompt    String
  intents   Json
  agents    Json
  execution Json
  reply     String
  createdAt DateTime @default(now())
}

model ProjectBuild {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id])

  label     String
  status    String   @default("draft")
  source    String   @default("brain_auto")
  domain    String   @default("website")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  artifacts ProjectBuildArtifact[]

  @@index([projectId])
  @@index([domain])
  @@index([status])
}

model ProjectBuildArtifact {
  id        String   @id @default(cuid())
  projectId String
  buildId   String

  build     ProjectBuild @relation(fields: [buildId], references: [id])

  kind      String
  payload   Json

  createdAt DateTime @default(now())

  @@index([projectId])
  @@index([buildId])
  @@index([kind])
}


model TradingWatchlist {
  id         String   @id @default(cuid())
  ownerEmail String  @unique
  name       String  @default("Default Watchlist")
  symbols    String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model TradingSignalAlert {
  id            String   @id @default(cuid())
  ownerEmail    String   @unique
  signal        String   @default("BUY WATCH")
  minConfidence Int      @default(75)
  isEnabled     Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model PublishedSite {
  id          String   @id @default(cuid())
  slug        String   @unique
  executionId String   @unique
  projectId   String
  ownerEmail  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model GuestAiUsage {
  id        String   @id @default(cuid())
  usageKey String   @unique
  count     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([usageKey])
}



model SugentEvent {
  id        String   @id @default(cuid())

  projectId String?
  buildId   String?
  artifactId String?
  executionId String?

  type      String
  domain    String?
  actor     String?
  message   String
  payload   Json?

  createdAt DateTime @default(now())

  @@index([projectId])
  @@index([buildId])
  @@index([artifactId])
  @@index([executionId])
  @@index([type])
  @@index([domain])
  @@index([createdAt])
}


model AuditLog {
  id        String   @id @default(cuid())

  projectId String
  project   Project  @relation(fields: [projectId], references: [id])

  actorType String
  actorId   String?

  action    String
  metadata  Json

  createdAt DateTime @default(now())

  @@index([projectId])
  @@index([actorType])
  @@index([action])
  @@index([createdAt])
}


model ProjectSafetySettings {
  id        String   @id @default(cuid())

  projectId String   @unique
  project   Project  @relation(fields: [projectId], references: [id])

  tradingMaxLeverage Int     @default(5)
  automationAllowExternal Boolean @default(false)
  websiteAllowCustomScripts Boolean @default(false)
  requireReviewBeforePublish Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
}


model CloudJob {
  id        String   @id @default(cuid())

  projectId String
  project   Project  @relation(fields: [projectId], references: [id])

  buildId   String?
  type      String
  status    String   @default("queued")
  payload   Json
  result    Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([buildId])
  @@index([type])
  @@index([status])
  @@index([createdAt])
}


model MarketplaceAgent {
  id          String   @id @default(cuid())
  name        String
  description String
  version     String   @default("1.0.0")
  inputSchema Json
  outputSchema Json
  endpoint    String
  status      String   @default("active")

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
}

model MarketplaceTool {
  id          String   @id @default(cuid())
  name        String
  description String
  configSchema Json
  endpoint    String
  status      String   @default("active")

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
}

model MarketplaceTemplate {
  id          String   @id @default(cuid())
  name        String
  description String
  domain      String
  draftKind   String
  draft       Json
  status      String   @default("active")

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([domain])
  @@index([draftKind])
  @@index([status])
  @@index([createdAt])
}


model TimelineEvent {
  id        String   @id @default(cuid())

  sessionId String
  projectId String?

  type      String
  payload   Json

  createdAt DateTime @default(now())

  @@index([sessionId])
  @@index([projectId])
  @@index([type])
  @@index([createdAt])
}

model TimelineSnapshot {
  id        String   @id @default(cuid())

  sessionId String
  projectId String?

  index     Int
  state     Json

  createdAt DateTime @default(now())

  @@index([sessionId])
  @@index([projectId])
  @@index([index])
  @@index([createdAt])
}


model MemoryRecord {
  id        String   @id @default(cuid())

  projectId String?
  sessionId String?

  type      String
  content   String
  embedding Json
  score     Float    @default(0)
  tags      String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([sessionId])
  @@index([type])
  @@index([score])
  @@index([createdAt])
}
